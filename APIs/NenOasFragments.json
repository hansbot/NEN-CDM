{
  "description": "Shared references for NEN Open API Specification. These definitions are not versioned, and can only be updated with non-breaking changes (i.e. additions)",
  "title": "Collection of Open API Specification Fragments and Standards Components to $ref to",
  "version": "0.9.0",
  "$comment": "Last modified on 2026-03-11 by Hans Bot - NEN.",
  "parameters": {
    "correlationId": {
      "name": "X-Correlation-Id",
      "description": "identifier to observe API request processing across the processing pipeline",
      "required": false,
      "in": "header",
      "schema": {
        "schema": {
            "$ref": "#/schemas/obsIds"
        }
      }
    }
  },
  "schemas": {
    "problemDetail": {
      "type": "object",
      "description": "Problem Details for HTTP APIs conform RFC 9457",
      "properties": {
        "type": {
            "type": "string",
            "format": "uri-reference",
            "description": "A URI reference that identifies the problem type.",
            "default": "about:blank"
        },
        "title": {
            "type": "string",
            "description": "A short, human-readable summary of the problem type.",
            "maxLength": 128
        },
        "status": {
            "type": "integer",
            "description": "The HTTP status code generated by the origin server for this occurrence of the problem.",
            "minimum": 100,
            "maximum": 599
        },
        "detail": {
            "type": "string",
            "description": "A human-readable explanation specific to this occurrence of the problem.",
            "maxLength": 2048
        },
        "instance": {
            "type": "string",
            "format": "uri-reference",
            "description": "A URI reference that identifies the specific occurrence of the problem. It may or may not yield further information if dereferenced."
        },
        "responseCorrelation": {
            "type": "string",
            "description": "A connection might be used for multiple request/response exchanges. The mechanism used to correlate between request and response messages is version dependent; some versions of HTTP use implicit ordering of messages, while others use an explicit identifier."
        },
        "validationErrors": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "detail": {
                        "type": "string",
                        "description": "clarification of the validation failure"
                    },
                    "pointer": {
                        "type": "string",
                        "description": "reference into the request message"
                    }
                },
                "required": ["detail"],
                "additionalProperties": true
            }
        },
        "required": ["title"],
        "additionalProperties": true
      }
    },
    "healthStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "timeChecked" 
        ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "UP", "DOWN"
          ]
        },
        "timeChecked": {
          "description": "point in time of status check",
          "$ref": "../CDM/NenDefinitions.json#/definitions/isoDateTimeExt"
        } 
      }
    },
    "errorRespons": {
        "headers": {
            "X-Correlation-Id": {
                "$ref": "#/headers/correlationId"
            }
        }
    },
    "obsIds": {
        "type": "object",
        "required": [],
        "properties": {
            "spanId": {
                "description": "identifier to observe all steps of a distributed system interaction",
                "type": "string",
                "format": "uuid",
                "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "traceId": {
                "description": "identifier to observe all steps of an end-to-end business transaction",
                "type": "string",
                "format": "uuid",
                "example": "123e4567-e89b-12d3-a456-426614174000"
            },
        "additionalProperties": false 
        }
    }
  },
  "headers": {
    "correlationId": { 
        "description": "identifier to observe API request processing across the processing pipeline",
        "required": false,
        "schema": {
            "$ref": "#/schemas/obsIds"
        }
    }
  },
  "responses": {
    "201": {
      "description": "Created (201)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "202": {
      "description": "Accepted (202)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "204": {
      "description": "No content; empty list (204)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "400": {
      "description": "Bad request (400)",
      "headers": {
        "$ref": "#/headers/correlationId"
      },
      "schema": {
          "$ref": "#/schemas/problemDetail" 
      }
    },
    "401": {
      "description": "Unauthorized; authentication issue (401)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "403": {
      "description": "Forbidden - no access (403)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "404": {
      "description": "Not found (404)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "408": {
      "description": "Timeout (408)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "429": {
      "description": "Too Many Requests - RFC 6585 (429)",
      "headers": {
        "$ref": "#/headers/correlationId"
      }
    },
    "500": {
      "description": "Internal Server Error (500)"
    },
    "503": {
      "description": "Service unavailable (503)"
    },
    "504": {
      "description": "Gateway Timeout (504)"
    }
  },
  "securitySchemes": {
    "jwtBearer": {
        "description": "Valid JWT bearer token as issued by a trusted Key Manager",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
    },
    "apiKey": {
        "description": "Key as generated by API Manager",
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
    },
    "clientCredentials": {
        "description": "OAuth client credential flow",
        "type": "oauth2",
        "in": "header",
        "name": "Authorization",
        "scheme": "http",
        "flows": {
            "clientCredentials" : {
                "tokenUrl": "https://api.nen.nl/authenticate"
            }
        }
    },
    "mutualTLS": {
        "description": "OAuth client credential flow"
    },
    "OIDC": {
        "description": "OAuth client credential flow"
    }
  }
}