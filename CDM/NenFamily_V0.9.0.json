{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "description": "Schema for NEN Family details",
  "title": "NenFamily Canonical Schema",
  "version": "0.9.0",
  "$comment": "Last modified on 2026-03-24 by Hans Bot - NEN. Added recursion to the family entity as indicated by Petra",
  "type": "object",
  "properties": {
    "nenFamilyId": {
        "$ref": "./NenIdentifiers.json#/definitions/nenFamilyId"
    },
    "nenFamilyURN": {
        "$ref": "./NenDefinitions.json#/definitions/nenFamilyURN"
    },
    "nenFamilyName": {
        "type": "string",
        "description": "Number owner concatenated with standard number",
        "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/138903736/nenFamily",
        "examples": [
            "NEN 7540", "ISO 7551", "ISO/IEC 27551", "EN 16601-00"
        ],
        "pattern": "^[A-Z/]+[ ]{1}[0-9]+$"
    },
    "nenFamilyDescriptions": {
        "type": "array",
        "items": {
            "type": "object",
            "properties": {
                "language": {
                    "$ref": "./NenDefinitions.json#/definitions/isoLanguageCode-1"
                },
                "localTopic": {
                    "type": "string",
                    "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/147652849/nenFamilyTopic"
                },
                "localFullTitle": {
                    "type": "string",
                    "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/143753258/nenFullTitle"
                },
                "localPartTitle": {
                    "type": "string",
                    "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/138444816/nenPartTitle"
                }
            },
            "additionalProperties": false
        },
        "minItems": 1,
        "maxItems": 5,
        "uniqueItems": true
    },
    "nenFamilyNumbers": {
        "type": "array",
        "description": "only for fit gap NEN Connect! Will not be populated after NEN Connect is phased out",
        "deprecated": true,
        "items": {
            "$ref": "./NenIdentifiers.json#/definitions/nenFamilyNumber"
        },
        "minItems": 0,
        "maxItems": 50,
        "uniqueItems": false
    },
    "nenFamilyTopic": {
        "description": "NenFamilyTopic will collect all the more topical metadata such as the ICS code and titles.",
        "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/147652849/nenFamilyTopic",
        "type": "object",
        "properties": {
            "nenFullTitle": {
                "description": "",
                "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/143753258/nenFullTitle",
                "type": "string",
                "examples": []
            },
            "nenPartTitle": {
                "description": "If applicable, preferably in both EN and NL, even if the standard will not (yet) be translated",
                "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/138444816/nenPartTitle",
                "type": "string",
                "examples": []
            },
            "nenOrder": {
                "description": "In cases where the the automated ordering of Poolparty does not suffice the order can be forced manually",
                "$comment": "missing details. Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/138346543/nenOrder",
                "type": "null"
            },
            "nenStandardType": {
                "$ref": "./NenDefinitions.json#/definitions/publicationTypes",
                "type": "string",
                "enum": [
                    "Guide",
                    "HD",
                    "HKZ",
                    "N",
                    "NTA",
                    "NVN",
                    "NPR",
                    "PGS",
                    "TR",
                    "TS"
                ]
            },
            "nenIcsCodes": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "This field contains the ICS code that classifies a Standard",
                        "$comment": "Internal reference: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/311197779/nenIcsCode",
                        "examples": ["85.040"],
                        "pattern": "^[0-9.]+$"
                    },
                    "details": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "language": {
                                    "$ref": "./NenDefinitions.json#/definitions/isoLanguageCode-1"
                                },
                                "localTitle": {
                                    "description": "The main title of the code.",
                                    "$comment": "Internal references: https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/141754726/nenIcsCodeTitleNl; https://nendelft.atlassian.net/wiki/spaces/Normenbank/pages/141656351/nenIcsCodeTitleEn",
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 256,
                                    "examples": [
                                        "Papierpulp", "Pulps"
                                    ]
                                },
                                "localScopeReference": {

                                },
                                "localScopeDescription": {

                                },
                                "localScope": {

                                }
                            },
                            "required": ["language"]
                        },
                        "uniqueItems": true
                    }
                },
                "additionalProperties": false,
                "required": []
            }
        }
    },
    "nenSustainableGoals": {
        "type": "object",
        "properties": {
            "reference": {

            },
            "title": {

            }
        }
    },
    "updatedAt": {
      "$ref": "./NenDefinitions.json#/definitions/updatedAt"
    },
    "references": {
        "nenFamilyAdmins": {
            "type": "array",
            "items": {
                "$ref": "./NenIdentifiers.json#/definitions/nenFamilyAdminId"
            },
            "minItems": 0,
            "maxItems": 24
        },
        "nenFamilies": {
            "type": "array",
            "items": {
                "$ref": "./NenIdentifiers.json#/definitions/nenFamilyId"
            },
            "minItems": 0,
            "maxItems": 24
        }   
    }
  },
  "required": [
    "nenFamilyId", 
    "updatedAt",
    "references"
    ],
  "additionalProperties": false
}