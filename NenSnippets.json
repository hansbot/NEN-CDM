"unusedProperties": {
    "stdPartNumber": {
        "$comment": "copied from 'cen-publications.yaml'. Unclear if this should go into references or be a separate property. For now, keeping it as a separate property for clarity, but it could be moved into the references array if it is considered a type of reference.",
        "description": "project's standard or document part 'number', which may also contain non-numeric characters, e.g. '2B'",
        "type": "string",
        "minLength": 1,
        "maxLength": 18,
        "examples": [
        "2B"
        ]
    },
    "stageCode": {
        "oneOf": [
        {
            "harmonizedStageCode": {
            "$comment": "copied from 'cen-publications.yaml'.",
            "description": "harmonizedStageCode (i.e. 60.60) cannot be used with stageCode. This will match any 'CURRENT' stage, not a 'CLOSED' stage.",
            "type": "string",
            "examples": [
                "00.60.0000", "40.97.0009", "90.00.0000"
            ],
            "pattern": "^[0-9]{2}\\.[0-9]{2}\\.[0-9]{4}$"
            }
        },
        {
            "stageCode": {
            "type": "string",
            "$comment": "copied from 'cen-publications.yaml'.",
            "description": "stageCode (i.e. 6060) cannot be used with harmonizedStageCode",
            "examples": [
                "6060"
            ],
            "pattern": "^[0-9]{4}$"
            }
        }
        ]
    },
    "nenCommitteeUrn": {
        "description": "URN for the NEN committee associated with the project, following a specific format (i.e. committeeUrn=iso:committee:54158&committeeUrn=iso:committee:48138&committeeUrn=iso:committee:4559).",
        "type": "string",
        "$comment": "to be redefined as array. copied from 'cen-publications.yaml'. pattern not consistent with description. Also, relation in metamodel is to nenFamily, not nenProject.",
        "examples": [
        "urn:nen:committee:12345"
        ],
        "pattern": "^urn:nen:committee:[0-9]+$"
    },
    "nenProjectRelationType": {
        "description": "project relation type, exact 'value'. (i.e. projectRelationType=ADOPTED_FROM&projectRelationType=JOINED_WORK_ITEM&projectRelationType=VIENNA_AGREEMENT)",
        "$comment": "seems deprecated in the metamodel",
        "type": "array",
        "items": {
            "type": "string"
        },
        "examples": [
        "ADOPTED_FROM", "JOINED_WORK_ITEM", "VIENNA_AGREEMENT"
        ]
    },
    "externalProjectId": {
        "description": "externalProjectId (i.e. iso:proj:21494)",
        "$comment": "copied from 'cen-publications.yaml'.",
        "type": "string",
        "examples": [
        "iso:proj:21494"
        ]
    },
    "mandateUrn": {
        "description": "Mandate urn, exact 'value'. (i.e. mandateUrn=cen:mandate:26)",
        "$comment": "copied from 'cen-publications.yaml'.",
        "type": "string",
        "examples": [
        "cen:mandate:26"
        ]
    },
    "mandateReference": {
        "description": "Mandate reference, exact 'value'. (i.e. mandateReference=M/396)",
        "$comment": "copied from 'cen-publications.yaml'.",
        "type": "string",
        "examples": [
        "M/396"
        ]
    },
    "directiveUrn": {
        "description": "Directive urn, exact 'value'. (i.e. directiveUrn=cen:directive:5218)",
        "$comment": "copied from 'cen-publications.yaml'.",
        "type": "string",
        "examples": [
        "cen:directive:5218"
        ]
    },
    "directiveReference": {
        "description": "Direct reference, exact 'value'. (i.e. directiveReference=2014/68/EU)",
        "$comment": "copied from 'cen-publications.yaml'.",
        "type": "string",
        "examples": [
        "2014/68/EU"
        ]
    },
    "originator":{
        "type": "string",
        "$comment": "ref hapi:docu:021.",
        "deprecated": true,
        "minLength": 3,
        "maxLength": 64,
        "description": "The acronym or name of an organization, partnership or group of SDOs that orginate a project, standard or publication. See also for NSIO: https://www.niso-sts.org/TagLibrary/niso-sts-TL-1-0-html/element/originator.html Open-ended list of values. Representation: Acronym. Example(s): CEN, CENELEC, CEN/CENELEC, IEC, ISO, ISO/IEC, ISO/IEC/IEEE, IEC/IEEE, IDF, ECMA, IEEE, ASTM, etc."
    },
    "intPublicationURNs": {
        "type": "array",
        "items": {
        "$ref": "#/definitions/publicationURNs"
        },
        "description": "Array of URNs related to the international publication. Each item in the array is a URN that identifies an international publication.",
        "minItems": 1,
        "maxItems": 5
    },
    "releaseItemURN": {
      "description": "URN for the NEN release item, following a specific format (i.e. urn:nen:releaseItem:12345).",
      "type": "string",
      "pattern": "^urn:nen:releaseItem:[0-9]+$",
      "examples": [
        "urn:nen:releaseItem:12345"
      ],
      "maxLength": 32
    },
    "nenPublicationTitles": {
        "type": "array",
        "$comment": "moved to nenProject",
        "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "isoLanguageCode": {
                "description": "ISO 639-1 language code for the publication title (e.g., 'en' for English, 'nl' for Dutch).",
                "type": "string",
                "pattern": "^[a-z]{2}$",
                "examples": [
                "en",
                "nl"
                ]
            },
            "nenPublicationTitle": {
                "description": "Title of the NEN publication in the specified language.",
                "type": "string",
                "maxLength": 512
            }
            }
        },
        "minItems": 1,
        "maxItems": 9
    },
    "stdTypeType": {
        "$ref": "#/definitions/publicationTypes"
    },
    "contentRef": {
      "type": "object",
      "description": "The reference to how / where to download the content of a releaseItem. Normally all releaseItems do have content, but there are exceptions when: the content is not available online (a physical-only, paper publication), or the content is online but not downloadable (an online database, eg. ISO 7010). Therefore this element is optional.",
    },
    "mimeType": {
      "type": "string",
      "description": "MIME type of the content at the URL.",
      "examples": [
        "application/pdf", "text/html", "application/xml"
      ],
      "maxLength": 255
    },
    "version": {
      "$comment": "hapi:docu:062",
      "type": "integer",
      "description": "Version number of the NEN release item, starting at 1 and incrementing by 1 for each new version.",
      "examples": [
        1, 2, 3
      ],
      "minimum": 1,
      "exclusiveMaximum": 1000
    }
}